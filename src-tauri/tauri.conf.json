{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VibePet",
  "version": "0.1.4",
  "identifier": "com.vibepet.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "VibePet",
        "url": "pet/index.html",
        "width": 192,
        "height": 208,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "config",
        "title": "桌宠管理面板",
        "url": "config/index.html",
        "width": 1000,
        "height": 720,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: http:; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost https: http:; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/pets/**", "../pets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "startMenuFolder": "VibePet"
      }
    }
  }
}
