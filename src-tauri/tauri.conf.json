{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VibePet",
  "version": "0.1.0",
  "identifier": "com.vibepet.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "VibePet",
        "url": "pet/index.html",
        "width": 192,
        "height": 208,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "config",
        "title": "VibePet - Config",
        "url": "config/index.html",
        "width": 800,
        "height": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
